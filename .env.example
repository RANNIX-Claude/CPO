# Frontend (Vite) — seguro exponer, son claves públicas por diseño de Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Solo para scripts locales de migración/seed (nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_DB_URL=postgresql://postgres:tu-password@db.tu-proyecto.supabase.co:5432/postgres

# Netlify Function (configurar en Netlify dashboard → Site settings → Environment variables,
# NO en este archivo local)
